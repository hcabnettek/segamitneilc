--- EXAMPLE 7: SharePoint — date filtering with ISO 8601 ---
USER_QUESTION: "Show me tasks due after March 1, 2025"
TABLE_SCHEMA: [
  { "InternalName": "ID", "Title": "ID", "TypeAsString": "Counter" },
  { "InternalName": "Title", "Title": "Task Name", "TypeAsString": "Text" },
  { "InternalName": "DueDate", "Title": "Due Date", "TypeAsString": "DateTime" },
  { "InternalName": "Status", "Title": "Status", "TypeAsString": "Choice" }
]
OUTPUT:
{
  "reasoning": "SharePoint source. Date comparison supported; using gt with ISO 8601 format on DueDate.",
  "FILTER_QUERY": [{ "item": "DueDate gt '2025-03-01T00:00:00Z'" }],
  "ORDER_BY":     [{ "item": "DueDate asc" }],
  "TOP_COUNT":    [{ "item": 5000 }],
  "SKIP_COUNT":   [{ "item": 0 }],
