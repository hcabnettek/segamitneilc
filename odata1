  "FILTER_QUERY": [{ "item": "AssignedTo/Title eq 'Sarah Connor'" }],
  "ORDER_BY":     [{ "item": "DueDate desc" }],
  "TOP_COUNT":    [{ "item": 5000 }],
  "SKIP_COUNT":   [{ "item": 0 }],
